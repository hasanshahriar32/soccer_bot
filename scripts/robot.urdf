<?xml version="1.0"?>
<robot name="soccer_bot">

  <!-- Base Link (Center of the robot on the ground) -->
  <link name="base_link">
  </link>

  <!-- Chassis (The main body of the robot) -->
  <link name="chassis">
    <visual>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <geometry>
        <!-- 33cm long, 17cm wide, 11cm tall -->
        <box size="0.33 0.17 0.11"/> 
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.3 0.8 0.8"/>
      </material>
    </visual>
  </link>

  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- Left Wheel (4cm wide, r=3.3cm) -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.033" length="0.04"/>
      </geometry>
      <material name="black">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="chassis_to_left_wheel" type="fixed">
    <parent link="chassis"/>
    <child link="left_wheel"/>
    <!-- 5cm from back → flip: now 5cm from front (+0.115 from center) -->
    <origin xyz="0.115 0.105 0.033" rpy="-1.5708 0 0"/>
  </joint>

  <!-- Right Wheel -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.033" length="0.04"/>
      </geometry>
      <material name="black">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="chassis_to_right_wheel" type="fixed">
    <parent link="chassis"/>
    <child link="right_wheel"/>
    <origin xyz="0.115 -0.105 0.033" rpy="-1.5708 0 0"/>
  </joint>

  <!-- Lidar Sensor (YDLidar X4) -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.04"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="base_to_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <!-- Centered X (0.0), 6.6cm from right (-0.019 Y), 9cm from bottom -->
    <origin xyz="0.0 -0.019 0.09" rpy="0 0 0"/>
  </joint>

  <!-- Pi Camera -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.01 0.03 0.03"/>
      </geometry>
      <material name="green">
        <color rgba="0.1 0.8 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="base_to_camera" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <!-- 0cm from front (0.165 X), 6.5cm from left (0.02 Y), 4.5cm from bottom -->
    <!-- Pointing forward: pitch 0, roll -1.5708 to fix orientation for camera frame -->
    <origin xyz="0.165 0.02 0.045" rpy="-1.5708 0 -1.5708"/>
  </joint>

</robot>
